# =============================================================================
# Mosaic — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl
MANIFEST

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.conda/

# ---------------------------------------------------------------------------
# Simulation run outputs
# Track the placeholder but NOT actual run data (too large for git).
# Individual run directories are auto-generated and reproducible from config.
# ---------------------------------------------------------------------------
runs/*/
!runs/.gitkeep

# ---------------------------------------------------------------------------
# Results — summary CSV is regenerated from runs, not hand-edited.
# Committed figures live in results/figures/ (tracked).
# ---------------------------------------------------------------------------
results/summary.csv

# ---------------------------------------------------------------------------
# Jupyter notebooks
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Testing / Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# ---------------------------------------------------------------------------
# Type checking
# ---------------------------------------------------------------------------
.mypy_cache/
.pytype/

# ---------------------------------------------------------------------------
# Environment variables
# ---------------------------------------------------------------------------
.env
.env.local

# ---------------------------------------------------------------------------
# Frontend (Node.js) — tracked separately in frontend/
# ---------------------------------------------------------------------------
node_modules/
frontend/dist/
frontend/.env
